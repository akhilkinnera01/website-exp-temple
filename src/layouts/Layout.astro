---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Varun Estates - Calm, respectful, confidence-building land buying experience." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Noto+Sans+Telugu:wght@300;400;500&family=Noto+Serif+Telugu:wght@400;600&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-[#F7F5F0] text-[#0A192F] font-sans antialiased overflow-x-hidden selection:bg-[#C49A6C] selection:text-[#F7F5F0]">
		<slot />
	</body>
</html>